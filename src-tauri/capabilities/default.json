{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-print",
    "core:event:default",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    }
  ]
}
